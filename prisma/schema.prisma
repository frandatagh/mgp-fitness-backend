generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelos de datos
model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String?
  routines             Routine[]
  contactMessages      ContactMessage[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  passwordResetTokens  PasswordResetToken[]
  profile              UserProfile?
  exerciseCheckins     ExerciseCheckin[]
  routineCheckins      RoutineCheckin[]
  runSessions          RunSession[]
  monthlyStatsArchives MonthlyStatsArchive[]
}

model Routine {
  id               String            @id @default(cuid())
  title            String
  notes            String?
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  exercises        Exercise[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastDoneAt       DateTime?
  exerciseCheckins ExerciseCheckin[]
  routineCheckins  RoutineCheckin[]

  @@index([userId])
}

model Exercise {
  id        String   @id @default(cuid())
  name      String
  sets      String? // Texto libre (ej: "3x10" o "3 al fallo")
  reps      String? // Texto libre (ej: "10-12" o "fallo")
  notes     String?
  day       String?
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  routineId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order            Int               @default(0)
  exerciseCheckins ExerciseCheckin[]

  @@index([routineId])
  @@index([routineId, order])
}

model ContactMessage {
  id          String @id @default(cuid())
  name        String
  email       String
  inquiryType String
  subject     String
  message     String

  sentFrom     String // 'authenticated' | 'guest'
  platform     String
  accountName  String?
  accountEmail String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  goal            String?
  heightCm        Float?
  weightKg        Float?
  birthDate       DateTime?
  profileImageUrl String?
  planType        String    @default("standard")
  weeklyKmGoal    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseCheckin {
  id          String   @id @default(cuid())
  userId      String
  routineId   String
  exerciseId  String
  score       Int
  notes       String?
  trackedDate String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId, trackedDate])
  @@index([userId, trackedDate])
  @@index([exerciseId, trackedDate])
  @@index([routineId, trackedDate])
}

model RoutineCheckin {
  id          String   @id @default(cuid())
  userId      String
  routineId   String
  score       Int
  trackedDate String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([userId, routineId, trackedDate])
  @@index([userId, trackedDate])
  @@index([routineId, trackedDate])
}

model RunSession {
  id              String   @id @default(cuid())
  userId          String
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  distanceMeters  Float
  avgPaceSecPerKm Float?
  maxSpeedMps     Float?
  pathGeoJson     Json?
  rating          Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MonthlyStatsArchive {
  id     String @id @default(cuid())
  userId String

  year  Int
  month Int

  runSessions            Int   @default(0)
  runningDistanceMeters  Float @default(0)
  runningDurationSeconds Int   @default(0)

  avgRunRating      Float?
  avgRoutineRating  Float?
  avgExerciseEffort Float?

  summary Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
}
